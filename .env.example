# URL base da API (cobranssas)
VITE_API_URL=https://twcapital.hml.cobransaas.com.br

# Secret de autenticação OAuth (Basic auth — formato Base64 de "clientId:clientSecret")
VITE_API_SECRET=SEU_SECRET_AQUI

# Meio de pagamento padrão (ID do cobrador na API)
# Exemplo: 1428801660272054272
VITE_MEIO_PAGAMENTO=

# Tempo de inatividade na tela de oportunidades antes de destacar a opcao a vista
# Token de integracao direto do servico /tracks (opcional)
# Quando informado, o portal usa esse bearer diretamente para sessoes, eventos e validacao por SMS
VITE_TRACKS_INTEGRATION_TOKEN=

VITE_OPORTUNIDADES_AVISTA_IDLE_MS=5000
